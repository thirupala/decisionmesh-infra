# Caddyfile — shared gateway (prod + staging on same box)

api.decimeshi.com {
    reverse_proxy dm-api:8080
    log {
        output stderr
        format json
        level WARN
    }
}

api-staging.decimeshi.com {
    reverse_proxy dm-api-staging:8081
    log {
        output stderr
        format json
        level WARN
    }
}
