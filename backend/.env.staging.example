# .env.staging — Staging environment variables
# Copy this to .env.staging and fill in values. NEVER commit .env.staging to git.

# ── Docker image ─────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/thirupala/decisionmesh:latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=decisionmesh
DB_USER=decisionmesh
DB_PASSWORD=staging-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=staging-redis-password

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Generate once: docker run --rm apache/kafka:3.7.0 kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=GENERATE_WITH_KAFKA_STORAGE_COMMAND

# ── OpenBao — DEV MODE ────────────────────────────────────────────────────────
# Fixed token for dev mode. Auto-unseals on start. No init needed.
VAULT_TOKEN=staging-root-token
