# .env.local — Local development environment variables
# Copy this to .env.local and fill in values. NEVER commit to git.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=decisionmesh
DB_USER=decisionmesh
DB_PASSWORD=decisionmesh

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=decisionmesh

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Generate once: docker run --rm apache/kafka:3.7.0 kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=GENERATE_WITH_KAFKA_STORAGE_COMMAND

# ── OpenBao — DEV MODE ────────────────────────────────────────────────────────
# Uses hashicorp/vault:1.15 in dev mode. Auto-unseals. Token is pinned.
VAULT_TOKEN=dev-root-token
