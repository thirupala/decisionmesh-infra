# .env.prod — Production environment variables
# Copy this to .env.prod and fill in values. NEVER commit .env.prod to git.

# ── Docker image ─────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/thirupala/decisionmesh:latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=decisionmesh
DB_USER=decisionmesh
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Generate once: docker run --rm apache/kafka:3.7.0 kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=GENERATE_WITH_KAFKA_STORAGE_COMMAND

# ── OpenBao ───────────────────────────────────────────────────────────────────
# Set after running: scripts/init-openbao-prod.sh
VAULT_TOKEN=SET_AFTER_OPENBAO_INIT
